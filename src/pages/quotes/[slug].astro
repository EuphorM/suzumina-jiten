---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RarityStars from '../../components/RarityStars.astro';

export async function getStaticPaths() {
  const entries = await getCollection('quotesMarkdown');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, reading, meaning, origin, tags, rarity } = entry.data;

function parseMdLinks(text: string): string {
  return text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
}
---

<BaseLayout title={title ?? '語録'}>
  <div class="breadcrumb">
    <a href="/">すずみな語録辞典</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/quotes">語録</a>
    <span class="breadcrumb-sep">›</span>
    {title}
  </div>

  {title && <h1>{title}</h1>}

  <div class="md-content">
    <table class="quote-info-table">
      <tbody>
        <tr>
          <th>読み</th>
          <td>{reading}</td>
        </tr>
        <tr>
          <th>意味</th>
          <td>{meaning}</td>
        </tr>
        <tr>
          <th>レア度</th>
          <td><RarityStars rarity={rarity} /></td>
        </tr>
        {tags.length > 0 && (
          <tr>
            <th>タグ</th>
            <td>
              <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
                {tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </td>
          </tr>
        )}
        {origin && (
          <tr>
            <th>由来</th>
            <td set:html={parseMdLinks(origin)} />
          </tr>
        )}
      </tbody>
    </table>
    <Content />
  </div>

  <script>
    // 「情報提供者：」で始まる段落をクレジットとしてスタイル適用
    document.querySelectorAll('.md-content p').forEach(p => {
      if (p.textContent.trimStart().startsWith('情報提供者：')) {
        p.classList.add('quote-contributor');
      }
    });

    // img + blockquote を quote-scene 構造にラップ
    document.querySelectorAll('.md-content img').forEach(img => {
      const imgContainer = img.parentElement?.tagName === 'P' ? img.parentElement : img;
      const next = imgContainer.nextElementSibling;
      if (next && next.tagName === 'BLOCKQUOTE') {
        const wrapper = document.createElement('div');
        wrapper.className = 'quote-scene';
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'quote-scene__avatar';
        const bubblesDiv = document.createElement('div');
        bubblesDiv.className = 'quote-scene__bubbles';
        next.style.marginLeft = 'auto';
        avatarDiv.appendChild(img);
        bubblesDiv.appendChild(next);
        wrapper.appendChild(avatarDiv);
        wrapper.appendChild(bubblesDiv);
        wrapper.classList.add('md-quote-scene');
        imgContainer.replaceWith(wrapper);
      }
    });
  </script>

  <div style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.875rem; color: var(--text-muted);">
    <a href="/quotes">← 語録一覧に戻る</a>
  </div>
</BaseLayout>

<style>
  .md-content :global(.quote-info-table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    font-size: 0.9375rem;
  }

  .md-content :global(.quote-info-table th),
  .md-content :global(.quote-info-table td) {
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
  }

  .md-content :global(.quote-info-table th) {
    width: 5em;
    color: var(--text-muted);
    font-weight: normal;
    white-space: nowrap;
  }

  .md-content :global(.quote-info-table tr:last-child th),
  .md-content :global(.quote-info-table tr:last-child td) {
    border-bottom: none;
  }

  .md-content :global(img) {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    display: block;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 640px) {
    .md-content :global(img) {
      width: 400px;
      max-width: 50vw;
    }
  }

  .md-content :global(blockquote) {
    position: relative;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 0 1rem 1rem 1rem;
    padding: 0.625rem 0.875rem;
    margin: 0 0 1rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 480px;
  }

  .md-content :global(blockquote p) {
    margin: 0;
  }

  .md-content :global(.quote-scene__bubbles blockquote) {
    width: fit-content;
    align-self: flex-end;
  }

  .md-content :global(.quote-contributor) {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-align: right;
    margin: 0.5rem 0 0;
  }
</style>

<style is:global>
  .md-quote-scene .quote-scene__bubbles blockquote {
    max-width: 480px;
  }
  @media (max-width: 639px) {
    .md-quote-scene .quote-scene__bubbles blockquote {
      max-width: 70%;
    }
  }
</style>
