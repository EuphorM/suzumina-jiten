---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RarityStars from '../../components/RarityStars.astro';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, reading, meaning, tags, rarity, first_appearance, youtube_url } = entry.data;
---

<BaseLayout title={title} description={`${title}（${reading}）— ${meaning}`}>
  <div class="breadcrumb">
    <a href="/">すずみな事典</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/quotes">語録</a>
    <span class="breadcrumb-sep">›</span>
    {title}
  </div>

  <h1>{title}</h1>

  <table class="quote-info-table">
    <tbody>
      <tr>
        <th>読み</th>
        <td>{reading}</td>
      </tr>
      <tr>
        <th>意味</th>
        <td>{meaning}</td>
      </tr>
      <tr>
        <th>レア度</th>
        <td><RarityStars rarity={rarity} /></td>
      </tr>
      {
        tags.length > 0 && (
          <tr>
            <th>タグ</th>
            <td>
              <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
                {tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </td>
          </tr>
        )
      }
      {
        first_appearance && (
          <tr>
            <th>初出</th>
            <td>{first_appearance}</td>
          </tr>
        )
      }
      {
        youtube_url && (
          <tr>
            <th>配信</th>
            <td>
              <a href={youtube_url} target="_blank" rel="noopener noreferrer">
                YouTube で見る →
              </a>
            </td>
          </tr>
        )
      }
    </tbody>
  </table>

  <div class="quote-content">
    <Content />
  </div>

  <div style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.875rem; color: var(--text-muted);">
    <a href="/quotes">← 語録一覧に戻る</a>
  </div>
</BaseLayout>
