---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RarityStars from '../../components/RarityStars.astro';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, reading, meaning, tags, rarity, first_appearance, first_date, youtube_url, image, usage, contributor, related_links } = entry.data;

function formatDate(dateStr: string): string {
  const uncertain = dateStr.endsWith('?');
  const parts = dateStr.replace('?', '').split('-');
  let formatted = '';
  if (parts[0]) formatted += `${parts[0]}年`;
  if (parts[1]) formatted += `${parseInt(parts[1])}月`;
  if (parts[2]) formatted += `${parseInt(parts[2])}日`;
  return uncertain ? `${formatted}（確認中）` : formatted;
}
---

<BaseLayout title={title} description={`${title}（${reading}）— ${meaning}`}>
  <div class="breadcrumb">
    <a href="/">すずみな語録辞典</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/quotes">語録</a>
    <span class="breadcrumb-sep">›</span>
    {title}
  </div>

  <h1>{title}</h1>

  <table class="quote-info-table">
    <tbody>
      <tr>
        <th>意味</th>
        <td>{meaning}</td>
      </tr>
      <tr>
        <th>読み</th>
        <td>{reading}</td>
      </tr>
      <tr>
        <th>レア度</th>
        <td><RarityStars rarity={rarity} /></td>
      </tr>
      {
        tags.length > 0 && (
          <tr>
            <th>タグ</th>
            <td>
              <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
                {tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </td>
          </tr>
        )
      }
      <tr>
        <th>起源</th>
        <td>
          {youtube_url ? (
            <a href={youtube_url} target="_blank" rel="noopener noreferrer">
              {first_appearance ?? 'YouTube で見る'}
            </a>
          ) : first_appearance ? (
            first_appearance
          ) : (
            <span style="color: var(--text-muted);">調査中</span>
          )}
        </td>
      </tr>
    </tbody>
  </table>

  <div class="quote-content">
    <Content />
  </div>

  {image && (
    <div class="quote-scene-wrapper">
      {usage.length > 0 && <p class="quote-scene__label">使用例</p>}
      <div class="quote-scene">
        <div class="quote-scene__avatar">
          <img src={image} alt={title} />
        </div>
        {usage.length > 0 && (
          <div class="quote-scene__bubbles">
            {usage.map((item) => (
              <div class="quote-bubble">
                {item.text}
                {item.date && <span class="quote-bubble__attr">――{formatDate(item.date)}涼花みなせ</span>}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

  {!image && usage.length > 0 && (
    <div class="quote-usage">
      <h2>使用例</h2>
      <ul>
        {usage.map((item) => (
          <li>
            {item.text}
            {item.date && <span class="quote-bubble__attr">――{formatDate(item.date)}涼花みなせ</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  {related_links.length > 0 && (
    <div class="quote-related-urls">
      <h2>関連リンク</h2>
      <ul>
        {related_links.map((item) => (
          <li>
            <a href={item.url} target="_blank" rel="noopener noreferrer">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {contributor.length > 0 && (
    <p class="quote-contributor">情報提供者：{contributor.join('・')}さん</p>
  )}

  <div style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.875rem; color: var(--text-muted);">
    <a href="/quotes">← 語録一覧に戻る</a>
  </div>
</BaseLayout>
