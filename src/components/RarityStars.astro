---
interface Props {
  rarity: number;
}

const { rarity } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rarity);

const labels: Record<number, string> = {
  1: '新規ファン必見',
  2: 'よく使う',
  3: '印象的・記憶に残る',
  4: '知る人ぞ知る',
  5: '激レア・名言・格言',
};
---

<span class="rarity">
  <span class="rarity-stars">
    {
      stars.map((filled) => (
        <span class={filled ? 'star star--filled' : 'star star--empty'}>
          {filled ? '★' : '☆'}
        </span>
      ))
    }
  </span>
  <span class="rarity-label">（{labels[rarity]}）</span>
</span>
